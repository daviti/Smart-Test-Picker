{
  "name": "smart-test-picker",
  "version": "1.0.0",
  "description": "AI-augmented test selector — reduces PR CI from 3h to 20 min without losing coverage",
  "author": "David Ortiz",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smart-pick": "ts-node src/cli.ts",
    "smart-pick:dry": "ts-node src/cli.ts --dry-run",
    "smart-pick:since": "ts-node src/cli.ts --since",
    "demo": "npm run build && cd web && npm install && npm run dev",
    "web": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
